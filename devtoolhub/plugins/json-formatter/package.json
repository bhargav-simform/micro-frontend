{
  "name": "json-formatter",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 3002 --strictPort",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview --port 3002 --strictPort",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@devtoolhub/event-bus": "workspace:*",
    "@devtoolhub/shared-types": "workspace:*",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@originjs/vite-plugin-federation": "^1.4.1",
    "@vitejs/plugin-vue": "^5.1.0",
    "typescript": "~5.5.4",
    "vite": "^6.0.0",
    "vue-tsc": "^2.0.0"
  }
}
